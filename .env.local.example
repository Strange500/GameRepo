# SteamGridDB API Key
# Get your API key from: https://www.steamgriddb.com/profile/preferences
STEAMGRIDDB_API_KEY=your_api_key_here

# Games Directory
# Path to directory containing game subdirectories
GAMES_DIR=/path/to/games

# Auto Install Game Command
# Base command used to install games (e.g., "wine" for Windows executables on Linux)
AUTO_INSTALL_GAME=wine
